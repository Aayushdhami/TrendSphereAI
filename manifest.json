{
  "manifest_version": 3,
  "name": "StockAI — Smart Stock Monitor",
  "version": "1.0.0",
  "description": "AI-Powered Stock Monitoring & Prediction Dashboard",
  "author": "StockAI Team",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "64": "assets/icon64.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "static/background/index.js"
  },
  "permissions": [
    "notifications",
    "storage",
    "alarms",
    "geolocation"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "64": "assets/icon64.png",
    "128": "assets/icon128.png"
  }
}
